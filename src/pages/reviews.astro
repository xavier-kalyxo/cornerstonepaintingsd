---
// Utils
import { getImage } from "astro:assets";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";
import ReviewsSection from "@components/Reviews/Reviews-1672.astro";

// Images
import landingImage from "@assets/images/hero/henrys-professional-painting-hero-interior-residential-painting-1920w.jpeg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout title="Customer Reviews | See What Our Clients Say" description="Read reviews from satisfied homeowners and businesses who trust Cornerstone Painting Co. for their interior and exterior painting projects in San Diego." heroImage={optimizedImage}>
	<Banner title="Reviews" image={optimizedImage} />
	<ReviewsSection />
	<div class="footer-spacer" aria-hidden="true"></div>
</BaseLayout>

<style>
	.footer-spacer {
		padding-bottom: calc(150 / 16 * 1rem);
	}
</style>

---
// Utils
import { getImage } from "astro:assets";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";

// Images
import landingImage from "@assets/images/hero/cornerstone-painting-co-hero-exterior-commercial-painting-1920w.jpeg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout title="Service Areas | Painting Throughout Greater San Diego" description="Cornerstone Painting Co. serves El Cajon, Santee, Spring Valley, Chula Vista, and communities throughout Greater San Diego County." heroImage={optimizedImage}>
	<Banner title="Service Areas" image={optimizedImage} />
	<!-- Page content goes here -->
	<div class="footer-spacer" aria-hidden="true"></div>
</BaseLayout>

<style>
	.footer-spacer {
		padding-bottom: calc(150 / 16 * 1rem);
	}
</style>

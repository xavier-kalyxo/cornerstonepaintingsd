---
// Utils
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import type { GetImageResult } from "astro";
import "@styles/root.less";

// Components
import Navigation2318 from "@components/Header/Navigation-2318.astro";
import Footer from "@components/Footer/Footer-1291.astro";
import Meta from "@components/Meta/Meta.astro";

// Data
import { SITE } from "@data/client";

// Create a union type for heroImage
type HeroImage = GetImageResult | ImageMetadata;

interface Props {
	title: string;
	description: string;
	heroImage?: HeroImage; // optional - passing a heroImage to BaseLayout will 1. preload the image and 2. use the image for og socials tags in the <head>
}

const { description, title, heroImage } = Astro.props as Props;
---

<html lang={SITE.locale}>
	<head>
		<!-- View Transitions support -->
		<ClientRouter />

		<!-- Fonts -->
		<Font cssVariable="--font-heading" preload />
		<Font cssVariable="--font-body" preload />

		<!-- SEO Meta Tags -->
		<Meta title={title} description={description} heroImage={heroImage}>
			<slot name="schema" slot="schema" />
		</Meta>

		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="Cornerstone Painting Co." />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- If present, preloads the image passed as a prop -->
		{heroImage && <link rel="preload" href={heroImage.src} as="image" />}

	</head>
	<body>
		<!-- Screen reader skip main nav -->
		<a class="skip" aria-label="skip to main content" href="#main">Click To Skip To Main Content</a>

		<Navigation2318 />
		<main id="main">
			<slot />
		</main>
		<Footer />

		<script>
			let currentObserver: IntersectionObserver | null = null;

			function initObserver() {
				// Mark body as ready for motion (No-JS Fallback)
				document.body.classList.add('motion-ready');

				const observerOptions = {
					root: null,
					rootMargin: '0px',
					threshold: 0.1
				};

				currentObserver = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('in-view');
							currentObserver?.unobserve(entry.target);
						}
					});
				}, observerOptions);

				// Query elements to observe
				const elements = document.querySelectorAll('.reveal-fade-up, .reveal-scale-in, .stagger-parent > *');
				elements.forEach(el => {
					// Auto-apply reveal-fade-up to children of stagger-parent to keep markup clean
					if (el.parentElement?.classList.contains('stagger-parent')) {
						el.classList.add('reveal-fade-up');
					}
					currentObserver?.observe(el);
				});
			}

			// Initialize on load and on view transitions
			document.addEventListener('astro:page-load', initObserver);

			// Cleanup observer before swapping pages
			document.addEventListener('astro:before-swap', () => {
				if (currentObserver) {
					currentObserver.disconnect();
					currentObserver = null;
				}
			});
		</script>
	</body>
</html>

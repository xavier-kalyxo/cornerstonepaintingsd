---
/**
 * WhyChooseUs — Trust signals / differentiators section.
 * Two variants: with background image (dark overlay) or without (warm-white bg).
 */

import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface TrustPoint {
	title: string;
	text: string;
}

interface Props {
	topper?: string;
	title: string;
	text?: string;
	points: TrustPoint[];
	backgroundImage?: ImageMetadata;
}

const { topper = "Why Cornerstone", title, text, points, backgroundImage } = Astro.props;
const hasImage = !!backgroundImage;
---

<section id="why-choose-us" class:list={[hasImage && "cs-has-image"]}>
	{hasImage && backgroundImage && (
		<Picture
			src={backgroundImage}
			alt=""
			width={1920}
			formats={["avif", "webp"]}
			pictureAttributes={{ class: "cs-background" }}
		/>
	)}
	<div class="cs-container">
		<div class="cs-header">
			<span class="cs-topper">{topper}</span>
			<h2 class="cs-title">{title}</h2>
			{text && <p class="cs-text">{text}</p>}
		</div>
		<ul class="cs-point-group">
			{points.map((point) => (
				<li class="cs-point">
					<h3 class="cs-h3">{point.title}</h3>
					<p class="cs-point-text">{point.text}</p>
				</li>
			))}
		</ul>
	</div>
</section>

<style lang="less">
	/* Mobile - 360px */
	@media only screen and (min-width: 0rem) {
		#why-choose-us {
			padding: var(--sectionPadding);
			background-color: var(--bg-secondary);
			position: relative;

			/* Image variant */
			&.cs-has-image {
				background-color: transparent;

				&:before {
					content: "";
					width: 100%;
					height: 100%;
					background: #000;
					opacity: 0.75;
					position: absolute;
					top: 0;
					left: 0;
					z-index: 1;
				}

				.cs-container {
					position: relative;
					z-index: 2;
				}

				.cs-topper {
					color: var(--primaryLight);
				}

				.cs-title,
				.cs-text,
				.cs-h3 {
					color: #fff;
				}

				.cs-point-text {
					color: rgba(255, 255, 255, 0.85);
				}

				.cs-point {
					border-color: rgba(255, 255, 255, 0.15);
				}
			}

			.cs-background {
				width: 100%;
				height: 100%;
				position: absolute;
				top: 0;
				left: 0;
				z-index: 0;

				img {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}
			}

			.cs-container {
				width: 100%;
				max-width: (1280/16rem);
				margin: auto;
				display: flex;
				flex-direction: column;
				gap: clamp(2rem, 4vw, 3rem);
			}

			.cs-header {
				width: 100%;
				max-width: (522/16rem);
			}

			.cs-title {
			}

			.cs-text {
				margin-top: (12/16rem);
			}

			.cs-point-group {
				width: 100%;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: 1fr;
				gap: (16/16rem);
			}

			.cs-point {
				list-style: none;
				padding: clamp(1rem, 2.5vw, 1.5rem);
				border: 1px solid #e0dcd7;
				border-radius: 0 (12/16rem) 0 (12/16rem);
			}

			.cs-h3 {
				font-size: clamp(1rem, 2vw, 1.125rem);
				font-weight: 700;
				line-height: 1.3;
				margin: 0 0 (6/16rem);
				color: var(--headerColor);
			}

			.cs-point-text {
				font-size: var(--bodyFontSize);
				line-height: 1.6;
				margin: 0;
				color: var(--bodyTextColor);
			}
		}
	}

	/* Tablet - 768px */
	@media only screen and (min-width: 48rem) {
		#why-choose-us {
			.cs-point-group {
				grid-template-columns: repeat(2, 1fr);
			}
		}
	}

	/* Desktop - 1024px */
	@media only screen and (min-width: 64rem) {
		#why-choose-us {
			.cs-container {
				flex-direction: row;
				justify-content: space-between;
				align-items: flex-start;
			}

			.cs-header {
				width: 38%;
				flex: none;
				position: sticky;
				top: (120/16rem);
			}

			.cs-point-group {
				width: 58%;
			}

			/* Image variant: horizontal layout for points */
			&.cs-has-image {
				.cs-container {
					flex-direction: column;
					align-items: center;
				}

				.cs-header {
					width: 100%;
					max-width: (700/16rem);
					text-align: center;
					position: static;
				}

				.cs-point-group {
					width: 100%;
					grid-template-columns: repeat(4, 1fr);
				}

				.cs-point {
					border: none;
					border-left: 2px solid rgba(255, 255, 255, 0.2);
					border-radius: 0;
					padding: 0 clamp(1rem, 2vw, 1.5rem);
				}
			}
		}
	}

</style>

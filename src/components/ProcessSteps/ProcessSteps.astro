---
/**
 * ProcessSteps — Numbered process/steps section (3-4 items).
 * Shows how a project works from inquiry to completion.
 */

interface Step {
	number: string;
	title: string;
	text: string;
}

interface Props {
	topper?: string;
	title: string;
	steps: Step[];
}

const { topper = "Our Process", title, steps } = Astro.props;
---

<section id="process-steps">
	<div class="cs-container">
		<div class="cs-content">
			<span class="cs-topper">{topper}</span>
			<h2 class="cs-title">{title}</h2>
		</div>
		<ul class="cs-step-group">
			{steps.map((step) => (
				<li class="cs-step">
					<span class="cs-number">{step.number}</span>
					<h3 class="cs-h3">{step.title}</h3>
					<p class="cs-step-text">{step.text}</p>
				</li>
			))}
		</ul>
	</div>
</section>

<style lang="less">
	/* Mobile - 360px */
	@media only screen and (min-width: 0rem) {
		#process-steps {
			padding: var(--sectionPadding);

			.cs-container {
				width: 100%;
				max-width: (1280/16rem);
				margin: auto;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: clamp(2rem, 4vw, 3rem);
			}

			.cs-content {
				text-align: center;
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.cs-title {
			}

			.cs-step-group {
				width: 100%;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: 1fr;
				gap: (24/16rem);
			}

			.cs-step {
				list-style: none;
				padding: clamp(1.25rem, 3vw, 2rem);
				padding-top: clamp(1.5rem, 3.5vw, 2.5rem);
				border-top: 1px solid #e8e8e8;
				position: relative;
			}

			.cs-number {
				font-family: var(--font-heading), sans-serif;
				font-size: clamp(2rem, 4vw, 2.75rem);
				font-weight: 700;
				line-height: 1;
				color: var(--primary);
				display: block;
				margin-bottom: (12/16rem);
			}

			.cs-h3 {
				font-size: clamp(1.0625rem, 2vw, 1.25rem);
				font-weight: 700;
				line-height: 1.3;
				margin: 0 0 (8/16rem);
				color: var(--headerColor);
			}

			.cs-step-text {
				font-size: var(--bodyFontSize);
				line-height: 1.6;
				margin: 0;
				color: var(--bodyTextColor);
			}
		}
	}

	/* Tablet - 768px */
	@media only screen and (min-width: 48rem) {
		#process-steps {
			.cs-step-group {
				grid-template-columns: repeat(2, 1fr);
			}
		}
	}

	/* Desktop - 1024px */
	@media only screen and (min-width: 64rem) {
		#process-steps {
			.cs-step-group {
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			}

			.cs-step {
				border-top: none;
				border-left: 1px solid #e8e8e8;

				&:first-child {
					border-left: none;
				}
			}
		}
	}

	/* Dark Mode */
	@media only screen and (min-width: 0rem) {
		body.dark-mode {
			#process-steps {
				.cs-topper {
					color: var(--primaryLight);
				}

				.cs-title,
				.cs-h3 {
					color: var(--bodyTextColorWhite);
				}

				.cs-number {
					color: var(--primaryLight);
				}

				.cs-step-text {
					color: var(--bodyTextColorWhite);
					opacity: 0.8;
				}

				.cs-step {
					border-color: var(--accent);
				}
			}
		}
	}
</style>

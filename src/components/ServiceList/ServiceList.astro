---
/**
 * ServiceList — Grid of service items with heading + description.
 * Supports light and dark background variants.
 */

interface ServiceItem {
	heading: string;
	text: string;
}

interface Props {
	topper: string;
	title: string;
	items: ServiceItem[];
	columns?: 1 | 2;
	background?: "light" | "dark";
}

const { topper, title, items, columns = 2, background = "light" } = Astro.props;
---

<section id="service-list" class:list={[background === "dark" && "cs-dark"]}>
	<div class="cs-container">
		<div class="cs-content">
			<span class="cs-topper">{topper}</span>
			<h2 class="cs-title">{title}</h2>
		</div>
		<ul class="cs-card-group" data-columns={columns}>
			{
				items.map((item) => (
					<li class="cs-item">
						<h3 class="cs-h3">{item.heading}</h3>
						<p class="cs-item-text">{item.text}</p>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style lang="less">
	/* Mobile - 360px */
	@media only screen and (min-width: 0rem) {
		#service-list {
			padding: var(--sectionPadding);
			background-color: #f7f7f7;

			&.cs-dark {
				background-color: var(--bg-dark);

				.cs-topper {
					color: var(--primaryLight);
				}

				.cs-title {
					color: var(--bodyTextColorWhite);
				}

				.cs-item {
					background-color: rgba(255, 255, 255, 0.05);
					border-left-color: var(--primaryLight);
				}

				.cs-h3 {
					color: var(--bodyTextColorWhite);
				}

				.cs-item-text {
					color: var(--bodyTextColorWhite);
					opacity: 0.8;
				}
			}

			.cs-container {
				width: 100%;
				max-width: (1280/16rem);
				margin: auto;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: clamp(2rem, 4vw, 3rem);
			}

			.cs-content {
				text-align: center;
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.cs-title {
				font-family: var(--font-heading), sans-serif;
				font-size: var(--headerFontSize);
				font-weight: 700;
				line-height: 1.2em;
				margin: 0 0 1rem;
				color: var(--headerColor);
				position: relative;
			}

			.cs-card-group {
				width: 100%;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: 1fr;
				gap: (16/16rem);
			}

			.cs-item {
				list-style: none;
				padding: clamp(1rem, 2.5vw, 1.5rem);
				padding-left: clamp(1.25rem, 3vw, 1.75rem);
				background-color: #fff;
				border-left: 3px solid var(--primary);
				border-radius: 0 (8/16rem) 0 (8/16rem);
			}

			.cs-h3 {
				font-size: clamp(1rem, 2vw, 1.125rem);
				font-weight: 700;
				line-height: 1.3;
				margin: 0 0 (6/16rem);
				color: var(--headerColor);
			}

			.cs-item-text {
				font-size: var(--bodyFontSize);
				line-height: 1.6;
				margin: 0;
				color: var(--bodyTextColor);
			}
		}
	}

	/* Tablet - 768px */
	@media only screen and (min-width: 48rem) {
		#service-list {
			.cs-card-group[data-columns="2"] {
				grid-template-columns: repeat(2, 1fr);
			}
		}
	}

	/* Desktop - 1024px */
	@media only screen and (min-width: 64rem) {
		#service-list {
			.cs-content {
				text-align: left;
				align-items: flex-start;
			}
		}
	}

</style>

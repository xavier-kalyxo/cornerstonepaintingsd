---
import { Image } from "astro:assets";
import photo1 from "@assets/photos/cornerstone-painting-co-content-home-01-1920w.webp";
import photo2 from "@assets/photos/cornerstone-painting-co-content-home-05-1920w.webp";
import photo3 from "@assets/photos/cornerstone-painting-co-content-home-06-1920w.webp";
import photo4 from "@assets/photos/cornerstone-painting-co-content-home-03-1920w.webp";
import photo5 from "@assets/photos/cornerstone-painting-co-content-home-08-1920w.webp";
import photo6 from "@assets/photos/cornerstone-painting-co-content-home-04-1920w.webp";
---

<!-- ============================================ --><!--                Side By Side                  --><!-- ============================================ -->
<section id="sbs-1285">
    <div class="cs-container">
        <div class="cs-image-group">
            <div class="cs-picture cs-picture1">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo1}
                    alt="freshly painted Spanish-style home exterior in Chula Vista"
                    width={244}
                    height={200}
                />
            </div>
            <div class="cs-picture cs-picture2">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo2}
                    alt="beautifully painted living room interior with warm tones"
                    width={244}
                    height={270}
                />
            </div>
            <div class="cs-picture cs-picture3">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo3}
                    alt="freshly painted modern multi-unit residential building exterior"
                    width={244}
                    height={270}
                />
            </div>
            <div class="cs-picture cs-picture4">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo4}
                    alt="commercial building exterior painting project in San Diego"
                    width={310}
                    height={343}
                />
            </div>
            <div class="cs-picture cs-picture5">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo5}
                    alt="freshly painted bedroom with clean neutral walls"
                    width={244}
                    height={270}
                />
            </div>
            <div class="cs-picture cs-picture6">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo6}
                    alt="professionally painted commercial storefront exterior"
                    width={244}
                    height={190}
                />
            </div>
            <!--Brush stroke decoration-->
            <img class="cs-brush-accent" src="/assets/decorations/brush-stroke-800w.webp" alt="" aria-hidden="true" loading="lazy" decoding="async" width="800" height="800" />
        </div>
        <div class="cs-content">
            <span class="cs-topper">Our Specialization</span>
            <h2 class="cs-title">
                Professional Painting for Your Home or Business
            </h2>
            <p class="cs-text">
                At Cornerstone Painting Co., we take pride in delivering
                exceptional painting services throughout the greater
                San Diego, CA area. Established in 1987, our company has built its
                reputation on dedication, craftsmanship, and a genuine commitment
                to customer satisfaction.
                Whether you need a fresh interior update for your home or a bold
                new look for your commercial property, our team of
                licensed, insured, and bonded professionals ensures every
                project is handled with precision and care.
            </p>
            <p class="cs-text">
                Our expertise covers both residential and commercial painting, with
                services customized to fit the unique needs of every client. We
                provide complimentary color consultations to help you find the perfect
                palette, and we use low-VOC, eco-conscious products whenever possible.
                With over 37 years of experience, we understand that great results
                come from attentive service and careful attention to detail. From
                surface preparation to the final coat, we're committed to making
                your vision a reality — on time and within budget.
            </p>
            <a href="/contact/" class="cs-button-solid">Get in Touch</a>
        </div>
    </div>
</section>

<style lang="less">
    /*-- -------------------------- -->
<---       Side By Side         -->
<--- -------------------------- -*/

    /* Mobile - 360px */
    @media only screen and (min-width: 0rem) {
        #sbs-1285 {
            padding: var(--sectionPadding);
            background-color: #f7f7f7;
            overflow: hidden;

            .cs-container {
                width: 100%;
                /* changes to 1280px at desktop */
                max-width: (550/16rem);
                margin: auto;
                display: flex;
                flex-direction: column;
                align-items: center;
                /* 48px - 64px */
                gap: clamp(3rem, 6vw, 4rem);
            }

            .cs-content {
                /* set text align to left if content needs to be left aligned */
                text-align: left;
                width: 100%;
                max-width: (522/16rem);
                display: flex;
                flex-direction: column;
                /* centers content horizontally, set to flex-start to left align */
                align-items: flex-start;
            }

            .cs-text {
                margin-bottom: (16/16rem);
                &:last-of-type {
                    margin-bottom: (32/16rem);
                }
            }

            .cs-ul {
                max-width: (630/16rem);
                margin: 0 0 (32/16rem) 0;
                padding: 0;
                /* clips the bullets to create the half circle */
                overflow: hidden;
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                gap: (12/16rem);
            }

            .cs-li {
                list-style: none;
                margin: 0;
                color: var(--bodyTextColor);
                display: flex;
                justify-content: flex-start;
                align-items: flex-start;
                gap: (12/16rem);
                position: relative;
            }

            .cs-button-solid {
                font-size: (16/16rem);
                /* 46px - 56px */
                line-height: clamp(2.875rem, 5.5vw, 3.5rem);
                text-decoration: none;
                font-weight: 700;
                text-align: center;
                margin: 0;
                color: #fff;
                min-width: (150/16rem);
                padding: 0 (24/16rem);
                background-color: var(--primary);
                border-radius: 0 (16/16rem) 0 (16/16rem);
                overflow: hidden;
                display: inline-block;
                position: relative;
                z-index: 1;
                /* prevents padding from adding to the width */
                box-sizing: border-box;

                &:before {
                    content: "";
                    position: absolute;
                    height: 100%;
                    width: 0%;
                    background: #000;
                    opacity: 1;
                    top: 0;
                    left: 0;
                    z-index: -1;
                    transition: width 0.3s;
                }

                &:hover {
                    &:before {
                        width: 100%;
                    }
                }
            }

            .cs-image-group {
                /* scales the whole group based on the view width size and stop when that vales equals .845em, resets at desktop */
                font-size: ~"min(2.207vw, 1em)";
                width: (545/16em);
                height: (793/16em);
                display: block;
                position: relative;
                z-index: 1;
            }

            .cs-picture {
                border-radius: (8/16em) (22/16em) (8/16em) (22/16em);
                overflow: hidden;
                position: absolute;

                img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    position: absolute;
                    top: 0;
                    left: 0;
                }
            }

            .cs-picture1 {
                width: (244/16em);
                height: (200/16em);
                top: (0/16em);
                left: (0/16em);
            }

            .cs-picture2 {
                width: (244/16em);
                height: (270/16em);
                top: (40/16em);
                right: (33/16em);
            }

            .cs-picture3 {
                width: (244/16em);
                height: (270/16em);
                top: (220/16em);
                left: 0;
            }

            .cs-picture4 {
                width: (310/16em);
                height: (343/16em);
                border-radius: 0 (30/16em) 0 (30/16em);
                box-shadow: 0px 24px 52px 0px rgba(0, 0, 0, 0.38);
                top: (294/16em);
                right: 0;
                z-index: 10;
            }

            .cs-picture5 {
                width: (244/16em);
                height: (270/16em);
                top: (510/16em);
                left: (0/16em);
            }

            .cs-picture6 {
                width: (244/16em);
                height: (190/16em);
                bottom: (0/16em);
                right: (33/16em);
            }

            .cs-brush-accent {
                width: 75%;
                height: auto;
                opacity: 0.10;
                position: absolute;
                bottom: -5%;
                left: -8%;
                z-index: -1;
                transform: rotate(-20deg);
                pointer-events: none;
            }
        }
    }

    /* Small Desktop - 1024px */
    @media only screen and (min-width: 64rem) {
        #sbs-1285 {
            .cs-container {
                max-width: (1280/16rem);
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
            }

            .cs-content {
                padding: (100/16rem) 0;
                align-self: center;
            }

            .cs-image-group {
                font-size: ~"min(1.2vw, 1em)";
                flex: none;
            }

            .cs-picture1 {
                border-radius: 0 (22/16rem) (22/16rem) (22/16rem);
            }

            .cs-picture6 {
                border-radius: (22/16rem) 0 (22/16rem) 0;
            }

        }
    }

    /* Large Desktop - 1200px */
    @media only screen and (min-width: 75rem) {
        #sbs-1285 {
            .cs-container {
                padding-left: (88/16rem);
                /* prevents padding and border from affecting height and width */
                box-sizing: border-box;
            }
        }
    }

</style>
